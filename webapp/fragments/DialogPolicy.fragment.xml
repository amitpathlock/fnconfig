<core:FragmentDefinition
	xmlns:core="sap.ui.core"
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form">
	<!-- @ui5ignore -->
	<Dialog class="PlDacDailogBox" 
   beforeOpen="onBeforePolAdminPolicyDialogOpened"
   afterOpen="onAfterPolAdminPolicyDialogOpen"
   contentWidth="620px" resizable="false" icon="{viewModel>/Icon}" title="{viewModel>/Title}">
		<content>
			<!-- @ui5ignore -->
			<f:SimpleForm editable="true" labelSpanXL="12" labelSpanL="12" labelSpanM="12" labelSpanS="12" layout="ResponsiveGridLayout" singleContainerFullSize="false">
				<f:content>
					<!-- @ui5ignore -->
					<Label text="{viewModel>/Name}" required="true" />
					<!-- @ui5ignore -->
					<Input id="idPolAdminPolName" maxLength="50"  enabled="{viewModel>/PolicyNameEnabled}" valueState="{viewModel>/PolNameErrorState}" valueStateText="{viewModel>/PolNameErrorMessage}" liveChange="onPolicyNameInputLiveChange" value="{PolicyName}" >
						<layoutData>
						<l:GridData span="XL1 L10 M10 S10" />
					</layoutData>
					</Input>
					<!-- @ui5ignore -->
					<Text  text="{Policy}" visible="false" id="idTextPolicy"/>
					<Input editable="false" value="{path:'Version',formatter:'.handleVersionFormat'}" >
					<layoutData>
						<l:GridData span="XL1 L2 M2 S2" />
					</layoutData>
					</Input>
					
					<Label text="{viewModel>/Description}" required="true" />
					<!-- @ui5ignore -->
					<Input id="idPolAdminPolDesc" maxLength="50" value="{PolicyDesc}" 
                submit="onSubmitPolAdminPolicyDesc"
               valueState="{viewModel>/PolDescErrorState}" valueStateText="{viewModel>/PolDescErrorMessage}" />
					<!-- Add more form fields as needed -->
					<!-- Add more form fields as needed -->
					<Label text="{i18n>lblPolApplicationArea}"  />
					<!-- @ui5ignore -->
					<Select  items="{/ApplicationAreaSet}" selectedKey="{ApplArea}">
							<items>
								<core:Item
									
									key="{ApplicationAreaID}"
									text="{ApplicationAreaText}"
									
								>
									
								</core:Item>
							</items>
							<layoutData>
						<l:GridData span="XL1 L8 M8 S8" />
					</layoutData>
					</Select>
					<Label text="{i18n>lblPolProcessArea}"  />
					<!-- @ui5ignore -->
					<Select  items="{/ProcessAreaSet}" selectedKey="{BusProcess}">
						<items>
								<core:Item
									
									key="{ProcessAreaID}"
									text="{ProcessAreaText}"
									
								>
									
								</core:Item>
							</items>
					<layoutData>
						<l:GridData span="XL1 L8 M8 S8" />
					</layoutData>
					</Select>
					<Label text="{i18n>lblPolLog}"  />
					<!-- @ui5ignore -->
					<Select items="{/AccessLogSet}" selectedKey="{AccessLog}" >
							<items>
								<core:Item
									key="{AccessLogValue}"
									text="{AccessLogText}"	
								>	
								</core:Item>
							</items>
					<layoutData>
						<l:GridData span="XL1 L6 M6 S6" />
					</layoutData>
					</Select>

					<Label text="{i18n>lblLongText}"  />
					<TextArea growing="true" rows="3" value="{Description}" maxLength="256" growingMaxLines="2"/>
				</f:content>
			</f:SimpleForm>
		</content>
		<beginButton>
			<!-- @ui5ignore -->
			<Button text="Save" press="onSavePolAdminPolicy" />
		</beginButton>
		<endButton>
			<!-- @ui5ignore -->
			<Button text="Cancel" press="onClosePolAdminPolicyDialog" />
		</endButton>
	</Dialog>
</core:FragmentDefinition>