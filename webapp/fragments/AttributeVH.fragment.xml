<c:FragmentDefinition
	xmlns="sap.ui.comp.valuehelpdialog"
	xmlns:c="sap.ui.core"
	
	xmlns:fb="sap.ui.comp.filterbar"
>
<!--@ui5ignore-->
<ValueHelpDialog 
		title="Attributes"
		ok=".onAttributeValueHelpOkPress"
		cancel=".onValueHelpCancelPress"
		afterClose=".onValueHelpAfterClose"
		supportRanges="true"
		key="AttributeId"
		descriptionKey="Description">  
		<!--@ui5ignore-->
		<fb:FilterBar advancedMode="true" search=".onFilterBarWithSuggestionsSearch" isRunningInValueHelpDialog="true">
		</fb:FilterBar>
        </ValueHelpDialog>
</c:FragmentDefinition>