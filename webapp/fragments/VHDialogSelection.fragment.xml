<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
    xmlns:cus="pl.dac.apps.fnconfig.control"
    xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
> <!-- @ui5ignore -->
   <Dialog showHeader="false" contentWidth="840px" contentHeight="580px" beforeOpen="onBeforeOpenDialog">   
        <content>
        <!-- @ui5ignore -->
          <cus:PlDacSectionLayout  addRowInSingleValue="onAddRowInSingleValue" addRowInValueRanges="onAddRowInValueRanges"
          >
              <cus:sections>
               
                    <!-- Single Values Selection Table-->
                    <VBox
                      
                    >
                        
                  
                     <Table items="{SingleValues>/}" sticky="HeaderToolbar,InfoToolbar,ColumnHeaders"  customData:title="Single Values" customData:icon="sap-icon://slim-arrow-down" >
                        <columns>
                         <Column 	  demandPopin="true">
                                <Text text="Selection Option" />
                            </Column> 
                            <Column 	  demandPopin="true">
                                <Text text="Values" />
                            </Column> 
                           
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle" type="Active">
                                <cells>
                                <!-- @ui5ignore -->
                                    <Select width="100%" change="onSelectionDialogOperatorChange" items="{path:'OperatorsSV>/',templateShareable:true}" selectedKey="{SingleValues>Operator}">
                                        
                                      
                                       <items>
                                        <c:Item key="{OperatorsSV>Key}" text="{OperatorsSV>Text}"
                                        customData:ClearType="ValueRange"
                                        >
                                            
                                        </c:Item>
                                       </items>
                                      
                                    </Select>
                                    <Input value="{SingleValues>Value}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                     <!-- @ui5ignore -->
                        <Button icon="sap-icon://add" text="Rows" class="plDacAddRows"  press=".onPressAddRowInValues" />    
                      </VBox>
                    <!-- Ranges Selection Table-->
                     <VBox>
                     <Table items="{Ranges>/}"  customData:title="Ranges" customData:icon="sap-icon://multi-select" sticky="HeaderToolbar,InfoToolbar,ColumnHeaders" >
                        <columns>
                         <Column 	  demandPopin="true">
                                <Text text="Selection Option" />
                            </Column> 
                            <Column 	  demandPopin="true">
                                <Text text="Lower Limit" />
                            </Column> 
                           <Column   demandPopin="true">
                                <Text text="Upper Limit" />
                            </Column> 
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle" type="Active">
                                <cells>
                                  <!-- @ui5ignore -->
                                    <Select  width="100%" change="onSelectionDialogOperatorChange" items="{path:'OperatorsRange>/',templateShareable:true}" selectedKey="{Ranges>Operator}">
                                        
                                       <items>
                                        <c:Item key="{OperatorsRange>Key}" text="{OperatorsRange>Text}" 
                                         customData:ClearType="Values" >
                                       
                                        </c:Item>
                                       </items>
                                      
                                    </Select>
                                    <Input value="{Ranges>Lower}"/>
                                     <Input value="{Ranges>Upper}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                    <!-- @ui5ignore -->
                        <Button icon="sap-icon://add" text="Rows" class="plDacAddRows"  press=".onPressAddRowInRanges" />    
                     </VBox>
                        <VBox>
                      <Table items="{path:'/EnvironmentAttSet'}" mode="SingleSelectLeft" customData:title="Env. Attributes"  customData:icon="sap-icon://world" >
                        <columns>
                            <Column 	minScreenWidth="Tablet"  demandPopin="true">
                                <Text text="{i18n>txtHeadrObjectPageExposeAttrTblColumnAttribute}" />
                            </Column> 
                             <Column 	minScreenWidth="Tablet"  demandPopin="true">
                                <Text text="{i18n>txtHeadrObjectPageExposeAttrTblColumnAttributeDesc}" />
                            </Column>     
                        </columns>
                        <items>
                          <!-- @ui5ignore -->
                            <ColumnListItem vAlign="Middle" type="Active" press="onPressAttributeItem">
                                <cells>
                                    <ObjectIdentifier title="{AttributeId}" />
                                    <Text text="{Description}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                     </VBox>
                     <VBox>
                      <Table items="{path:'/UserAttrSet'}" mode="SingleSelectLeft" customData:title="User Attributes"  customData:icon="sap-icon://person-placeholder" >
                        <columns>
                            <Column 	minScreenWidth="Tablet"  demandPopin="true">
                                <Text text="{i18n>txtHeadrObjectPageExposeAttrTblColumnAttribute}" />
                            </Column> 
                             <Column 	minScreenWidth="Tablet"  demandPopin="true">
                                <Text text="{i18n>txtHeadrObjectPageExposeAttrTblColumnAttributeDesc}" />
                            </Column>     
                        </columns>
                        <items>
                          <!-- @ui5ignore -->
                            <ColumnListItem vAlign="Middle" type="Active" press="onPressAttributeItem">
                                <cells>
                                    <ObjectIdentifier title="{AttributeId}" />
                                    <Text text="{Description}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                     </VBox>
                     <VBox>
                     <!-- @ui5ignore -->
                      <Table items="{path:'/ListSet'}" class="plDacDialgTable" mode="SingleSelectLeft"  sticky="HeaderToolbar,InfoToolbar,ColumnHeaders"
                       customData:title="List"  customData:icon="sap-icon://activities" alternateRowColors="true">
                        <columns>
                            <Column 	minScreenWidth="Tablet"  demandPopin="true">
                                <Text text="Name" />
                            </Column> 
                             <Column 	minScreenWidth="Tablet"  demandPopin="true">
                                <Text text="Description" />
                            </Column>     
                        </columns>
                        <items>
                          <!-- @ui5ignore -->
                            <ColumnListItem class="plDacRowSelected" vAlign="Middle" type="Active" press="onPressAttributeItem">
                                <cells>
                                    <ObjectIdentifier title="{ListId}" />
                                    <Text text="{Description}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                     </VBox>
              </cus:sections>
          </cus:PlDacSectionLayout>

        </content> 
            <beginButton>
                 <!-- @ui5ignore -->
             <Button text="Ok" press="onValueDialogOkPress" visible="{viewModel>/VisibleOK}" />
            </beginButton> 
          <endButton>
          
           <!-- @ui5ignore -->
                <Button text="Cancel" press="onCloseValueDialog" />
            </endButton>      
    </Dialog>
</c:FragmentDefinition>